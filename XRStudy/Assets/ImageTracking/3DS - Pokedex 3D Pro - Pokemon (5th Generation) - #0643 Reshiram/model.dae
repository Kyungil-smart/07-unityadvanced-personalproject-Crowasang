                    </sampler2D>
                </newparam>
                <technique sid="standard">
                    <phong>
                        <emission>
                            <color sid="emission">0 0 0 1</color>
                        </emission>
                        <ambient>
                            <color sid="ambient">0 0 0 1</color>
                        </ambient>
                        <diffuse>
                            <texture texture="EfReshiram_circle01_ctr-image_sampler" texcoord="CHANNEL0" />
                        </diffuse>
                        <specular>
                            <color sid="specular">0 0 0 1</color>
                        </specular>
                        <reflective>
                            <color sid="reflective">1 1 1 1</color>
                        </reflective>
                        <shininess>
                            <float sid="shininess">20</float>
                        </shininess>
                        <reflectivity>
                            <float sid="reflectivity">1</float>
                        </reflectivity>
                        <transparency>
